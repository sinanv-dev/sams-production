rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Read the caller's own Firestore profile. Only call this after confirming
    // the target document is NOT the caller's own doc, to avoid circular reads.
    function callerData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function callerExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Safe role helpers — only valid when the caller is NOT reading their own doc.
    function isAdmin() {
      return isAuthenticated() && callerExists() && callerData().role == 'admin';
    }

    function isPropertyOwner() {
      return isAuthenticated() && callerExists() && callerData().role == 'owner';
    }

    function ownsApartment(apartmentId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/apartments/$(apartmentId)) &&
        get(/databases/$(database)/documents/apartments/$(apartmentId)).data.ownerId == request.auth.uid;
    }

    // ─── Users Collection ─────────────────────────────────────────────────────
    // KEY FIX: Any authenticated user may always read/write their OWN document
    // (userId == request.auth.uid). This avoids the circular read: the isAdmin()
    // helper calls callerData() which reads /users/{callerUid}. If callerUid ==
    // userId the rule would recurse forever. By granting self-access first with
    // a plain uid equality check, no helper function is needed.
    match /users/{userId} {
      // Self-read: always allowed – no helper needed, no circular dependency.
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Admins can read any user. Safe: callerData() reads a DIFFERENT doc.
      allow read: if isAuthenticated() && request.auth.uid != userId && isAdmin();

      // Owners can read their own customers.
      allow read: if isAuthenticated() && request.auth.uid != userId &&
        isPropertyOwner() &&
        resource.data.role == 'customer' &&
        resource.data.ownerId == request.auth.uid;

      // Create: any authenticated user can create their own doc (signup flow),
      // or an admin can create any doc.
      allow create: if isAuthenticated() && (
        request.auth.uid == userId ||
        request.resource.data.role == 'customer' ||
        isAdmin()
      );

      // Update: self or admin or owner updating their customer.
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        (request.auth.uid != userId && isAdmin()) ||
        (request.auth.uid != userId && isPropertyOwner() &&
          resource.data.role == 'customer' &&
          resource.data.ownerId == request.auth.uid)
      );

      allow delete: if isAuthenticated() && request.auth.uid != userId && isAdmin();
    }

    // ─── Apartments Collection ────────────────────────────────────────────────
    match /apartments/{apartmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isPropertyOwner() && (
        resource == null || resource.data.ownerId == request.auth.uid
      ) && request.resource.data.ownerId == request.auth.uid);
    }

    // ─── Rooms Collection ─────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isPropertyOwner() &&
        ownsApartment(request.resource.data.apartmentId || resource.data.apartmentId)
      );
    }

    // ─── Apartment Requests (Visit Requests) ─────────────────────────────────
    match /apartmentRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isAdmin() ||
        (isPropertyOwner() && ownsApartment(resource.data.apartmentId))
      );
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin() || (isPropertyOwner() && (
        ownsApartment(resource.data.apartmentId) || ownsApartment(request.resource.data.apartmentId)
      ));
    }

    // ─── Payments Collection ──────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isAdmin() ||
        (isPropertyOwner() && ownsApartment(resource.data.apartmentId))
      );
      allow write: if isAdmin() || (isPropertyOwner() && (
        ownsApartment(resource.data.apartmentId) || ownsApartment(request.resource.data.apartmentId)
      ));
    }

    // ─── Electricity Bills Collection ─────────────────────────────────────────
    match /electricity_bills/{billId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isAdmin() ||
        (isPropertyOwner() && ownsApartment(resource.data.apartmentId))
      );
      allow write: if isAdmin() || (isPropertyOwner() && (
        ownsApartment(resource.data.apartmentId) || ownsApartment(request.resource.data.apartmentId)
      ));
    }

    // ─── Complaints Collection ────────────────────────────────────────────────
    match /complaints/{complaintId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isAdmin() ||
        (isPropertyOwner() && ownsApartment(resource.data.apartmentId))
      );
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isAdmin() ||
        (isPropertyOwner() && ownsApartment(resource.data.apartmentId))
      );
      allow delete: if isAdmin();
    }

    // ─── Notifications Collection ─────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated();
    }
  }
}

